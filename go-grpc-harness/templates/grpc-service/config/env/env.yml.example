# 运行配置模板。
# 复制为同目录 env.yml 并填入真实值;env.yml 已被 .gitignore 忽略,不入库。
# 注意:配置为严格解析(KnownFields),未知/拼错的键会导致启动失败(fail-fast,防静默失效)。
env: dev

log:
  level: "info" # debug/info/warn/error,缺省 info
  json: false # true 输出 JSON 结构化格式(生产采集建议开);显式开关,不按 env 推导

grpc:
  addr: ":9090"
  # 全局 QPS 限流(令牌桶,burst=qps);0 或删除此行 = 关闭。生产建议按调用方容量显式设置。
  ratelimitqps: 100
  shutdowntimeoutseconds: 30 # 优雅关闭等待上限,超时强制 Stop

mysql:
  host: "127.0.0.1"
  port: "3306"
  user: "root"
  password: "" # 真实密码只写进 env.yml,勿提交
  dbname: "your_db"
  # charset/parseTime/loc 无需配置(ormx 默认等价 charset=utf8mb4&parseTime=True&loc=Local)
  maxidleconn: 10 # 须 <= maxopenconn(GORM 约束)
  maxopenconn: 50
  maxlifeseconds: 3600
