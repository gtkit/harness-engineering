# 运行配置不入库,仅保留 example 模板(严格解析,见 config/env/env.yml.example)
config/env/*.yml
!config/env/*.yml.example

# 构建产物
bin/
*.log

# buf export 产物(供 GoLand 解析 proto import,由 make proto-export 重生)
.proto-deps/

# IDE / 系统
.idea/
.vscode/
.DS_Store
go.work
go.work.sum

# 说明:AGENTS.md/CLAUDE.md/.harness/ 等本地工具/规则文件由 harness setup.sh 本地生成、
# 不入库;setup 会把它们的忽略规则写进 .git/info/exclude(仅本地、不进版本库),
# 而非本文件——clone 本仓库后先跑 setup.sh。
